# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Connection Mode: "cloud" or "local"
CONNECTION_MODE=cloud

# Tuya Cloud API (required for cloud mode)
TUYA_API_KEY=your_api_key_here
TUYA_API_SECRET=your_api_secret_here
TUYA_API_REGION=us

# Tuya Device
DEVICE_ID=eb87d3012cc8f3b11cpxqy

# Local mode only
DEVICE_IP=192.168.18.25
LOCAL_KEY=your_local_key_here
DEVICE_VERSION=3.4

# Monitoring
POLL_INTERVAL_SECONDS=60
LOW_BALANCE_KWH=10
